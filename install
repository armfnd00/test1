#!/usr/bin/env bash
set -Eeuo pipefail

APP_NAME="${APP_NAME:-beautynet}"
PROJECT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
WHEEL_BASE="${PROJECT_DIR}/packages/linux"
NGINX_DEB_DIR="${PROJECT_DIR}/packages/nginx"
WHEEL_DIR=""
VENV_DIR="${PROJECT_DIR}/.venv"
ENV_FILE="${PROJECT_DIR}/.env"
LOG_DIR="${PROJECT_DIR}/logs"
PYTHON_BIN="${PYTHON_BIN:-python3.12}"
BIND_ADDRESS="${BEAUTYNET_BIND:-127.0.0.1:8000}"
GUNICORN_WORKERS="${GUNICORN_WORKERS:-3}"
GUNICORN_TIMEOUT="${GUNICORN_TIMEOUT:-90}"
DEFAULT_DOMAIN="server-72c79137-9758-4104-82cb-eead932ef986.ir-thr-fr1.arvancompute.ir"
DEFAULT_ORIGIN="http://${DEFAULT_DOMAIN}"
USE_NGINX="${BEAUTYNET_USE_NGINX:-true}"
NGINX_ACTIVE=0

info() {
    printf '\033[1;32m[BeautyNet]\033[0m %s\n' "$*"
}

warn() {
    printf '\033[1;33m[BeautyNet]\033[0m %s\n' "$*"
}

die() {
    printf '\033[1;31m[BeautyNet]\033[0m %s\n' "$*" >&2
    exit 1
}

need_cmd() {
    command -v "$1" >/dev/null 2>&1 || die "Command not found: $1"
}

pick_python() {
    if command -v "$PYTHON_BIN" >/dev/null 2>&1; then
        printf '%s' "$PYTHON_BIN"
        return
    fi
    if command -v python3.12 >/dev/null 2>&1; then
        printf '%s' "python3.12"
        return
    fi
    if command -v python3.11 >/dev/null 2>&1; then
        printf '%s' "python3.11"
        return
    fi
    if command -v python3 >/dev/null 2>&1; then
        printf '%s' "python3"
        return
    fi
    die "Python 3.11 or 3.12 is required. Install Python, then run ./install again."
}

get_python_version() {
    local py="$1"
    "$py" - <<'PY'
import sys
print(f"{sys.version_info.major}.{sys.version_info.minor}")
PY
}

select_wheelhouse() {
    local version tag candidate
    version="$(get_python_version "$PYTHON")"
    tag="${version/./}"
    candidate="${WHEEL_BASE}/py${tag}"

    if [ -d "$candidate" ] && ls "$candidate"/*.whl >/dev/null 2>&1; then
        WHEEL_DIR="$candidate"
    elif [ "$version" = "3.11" ] && [ -d "$WHEEL_BASE" ] && ls "$WHEEL_BASE"/*.whl >/dev/null 2>&1; then
        WHEEL_DIR="$WHEEL_BASE"
    else
        die "No offline wheelhouse found for Python ${version}. Expected: ${candidate}"
    fi

    info "Using Python ${version}: ${PYTHON}"
    info "Using offline wheelhouse: ${WHEEL_DIR}"
}

assert_wheelhouse() {
    [ -d "$WHEEL_DIR" ] || die "Missing offline wheel folder: ${WHEEL_DIR}"
    ls "$WHEEL_DIR"/*.whl >/dev/null 2>&1 || die "No .whl files found in ${WHEEL_DIR}"
    if ls "$WHEEL_DIR"/*win_amd64*.whl >/dev/null 2>&1; then
        die "Windows wheels found in ${WHEEL_DIR}. Use Linux wheels only."
    fi
}

write_default_env() {
    if [ -f "$ENV_FILE" ]; then
        info ".env exists; keeping current environment."
        return
    fi

    local secret
    secret="$("${PYTHON}" - <<'PY'
import secrets
print(secrets.token_urlsafe(64))
PY
)"

    cat > "$ENV_FILE" <<EOF
# Auto-generated by ./install.
# Edit this file after first boot if you want PostgreSQL, HTTPS, or a real domain.
DJANGO_SECRET_KEY=${secret}
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=${BEAUTYNET_HOSTS:-${DEFAULT_DOMAIN},localhost,127.0.0.1}
CSRF_TRUSTED_ORIGINS=${BEAUTYNET_CSRF_TRUSTED_ORIGINS:-${DEFAULT_ORIGIN}}
CORS_ALLOWED_ORIGINS=${BEAUTYNET_CORS_ALLOWED_ORIGINS:-${DEFAULT_ORIGIN}}

# Fully offline first boot uses SQLite so the app can start without database packages.
# For PostgreSQL, replace these DB_* values before running ./install:
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=beautynet_db
# DB_USER=postgres
# DB_PASSWORD=your-password
# DB_HOST=localhost
# DB_PORT=5432
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=${PROJECT_DIR}/db.sqlite3
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

SERVE_MEDIA=True
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
THROTTLE_ANON=120/hour
THROTTLE_USER=600/hour
BEAUTYNET_USE_NGINX=True
BEAUTYNET_BIND=127.0.0.1:8000
BEAUTYNET_SERVER_NAME=${DEFAULT_DOMAIN}
EOF
    chmod 600 "$ENV_FILE" || true
    info "Created .env for offline first boot."
}

load_env() {
    set -a
    # shellcheck disable=SC1090
    . "$ENV_FILE"
    set +a
}

install_python_packages() {
    info "Creating virtualenv..."
    "$PYTHON" -m venv "$VENV_DIR"
    # shellcheck disable=SC1091
    . "${VENV_DIR}/bin/activate"

    info "Installing Python packages from local wheelhouse only..."
    python -m ensurepip --upgrade >/dev/null 2>&1 || true
    python -m pip install --no-index --find-links "$WHEEL_DIR" --upgrade pip setuptools wheel
    python -m pip install --no-index --find-links "$WHEEL_DIR" -r "${PROJECT_DIR}/requirements.txt"
}

run_django_setup() {
    # shellcheck disable=SC1091
    . "${VENV_DIR}/bin/activate"
    load_env

    mkdir -p "$LOG_DIR" "${PROJECT_DIR}/media" "${PROJECT_DIR}/staticfiles"

    info "Running Django checks..."
    python manage.py check
    if [ "${DJANGO_DEBUG:-False}" = "False" ]; then
        python manage.py check --deploy || warn "Django deploy check reported warnings; review before public launch."
    fi

    info "Collecting static files..."
    python manage.py collectstatic --noinput --clear

    info "Applying database migrations..."
    python manage.py migrate --noinput

    if [ -f "${PROJECT_DIR}/accounts/management/commands/bootstrap_wallets.py" ]; then
        info "Bootstrapping wallets..."
        python manage.py bootstrap_wallets || warn "Wallet bootstrap skipped or already done."
    fi
}

runtime_user() {
    printf '%s' "${BEAUTYNET_RUN_USER:-${SUDO_USER:-$(id -un)}}"
}

ensure_runtime_permissions() {
    local run_user run_group
    run_user="$(runtime_user)"
    if ! id "$run_user" >/dev/null 2>&1; then
        warn "Runtime user ${run_user} was not found; skipping ownership fix."
        return 0
    fi
    run_group="$(id -gn "$run_user")"

    mkdir -p "$LOG_DIR" "${PROJECT_DIR}/media" "${PROJECT_DIR}/staticfiles"

    if [ "$(id -u)" -eq 0 ]; then
        chown -R "${run_user}:${run_group}" "$LOG_DIR" "${PROJECT_DIR}/media" "${PROJECT_DIR}/staticfiles"
        [ -f "${PROJECT_DIR}/db.sqlite3" ] && chown "${run_user}:${run_group}" "${PROJECT_DIR}/db.sqlite3"
    elif command -v sudo >/dev/null 2>&1; then
        sudo chown -R "${run_user}:${run_group}" "$LOG_DIR" "${PROJECT_DIR}/media" "${PROJECT_DIR}/staticfiles" || warn "Could not chown runtime folders."
        [ -f "${PROJECT_DIR}/db.sqlite3" ] && sudo chown "${run_user}:${run_group}" "${PROJECT_DIR}/db.sqlite3" || true
    fi

    chmod -R u+rwX,g+rwX "$LOG_DIR" "${PROJECT_DIR}/media" "${PROJECT_DIR}/staticfiles" || true
    info "Runtime folders are writable by ${run_user}."
}

install_systemd_service() {
    if ! command -v systemctl >/dev/null 2>&1; then
        return 1
    fi

    local service_path="/etc/systemd/system/${APP_NAME}.service"
    local run_user
    run_user="$(runtime_user)"

    if [ "$(id -u)" -ne 0 ]; then
        if ! command -v sudo >/dev/null 2>&1; then
            return 1
        fi
        warn "systemd setup needs sudo; you may be asked for password."
        sudo tee "$service_path" >/dev/null <<EOF
[Unit]
Description=BeautyNet Django application
After=network.target

[Service]
Type=simple
User=${run_user}
WorkingDirectory=${PROJECT_DIR}
EnvironmentFile=${ENV_FILE}
ExecStart=${VENV_DIR}/bin/gunicorn beautynet.wsgi:application --bind ${BIND_ADDRESS} --workers ${GUNICORN_WORKERS} --timeout ${GUNICORN_TIMEOUT} --access-logfile - --error-logfile -
Restart=always
RestartSec=5
AmbientCapabilities=CAP_NET_BIND_SERVICE
CapabilityBoundingSet=CAP_NET_BIND_SERVICE
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
EOF
        sudo systemctl daemon-reload
        sudo systemctl enable "${APP_NAME}"
        sudo systemctl restart "${APP_NAME}"
        return 0
    fi

    cat > "$service_path" <<EOF
[Unit]
Description=BeautyNet Django application
After=network.target

[Service]
Type=simple
User=${run_user}
WorkingDirectory=${PROJECT_DIR}
EnvironmentFile=${ENV_FILE}
ExecStart=${VENV_DIR}/bin/gunicorn beautynet.wsgi:application --bind ${BIND_ADDRESS} --workers ${GUNICORN_WORKERS} --timeout ${GUNICORN_TIMEOUT} --access-logfile - --error-logfile -
Restart=always
RestartSec=5
AmbientCapabilities=CAP_NET_BIND_SERVICE
CapabilityBoundingSet=CAP_NET_BIND_SERVICE
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
EOF
    systemctl daemon-reload
    systemctl enable "${APP_NAME}"
    systemctl restart "${APP_NAME}"
}

install_nginx_proxy() {
    case "${USE_NGINX,,}" in
        1|true|yes) ;;
        *) return 0 ;;
    esac
    if ! command -v nginx >/dev/null 2>&1; then
        info "nginx is not installed; trying local offline packages..."
        if [ -d "$NGINX_DEB_DIR" ] && ls "$NGINX_DEB_DIR"/*.deb >/dev/null 2>&1; then
            if [ "$(id -u)" -ne 0 ]; then
                sudo dpkg -i "$NGINX_DEB_DIR"/*.deb || die "Offline nginx install failed. Put all required .deb dependencies in ${NGINX_DEB_DIR}."
            else
                dpkg -i "$NGINX_DEB_DIR"/*.deb || die "Offline nginx install failed. Put all required .deb dependencies in ${NGINX_DEB_DIR}."
            fi
        else
            die "nginx is missing and no offline .deb packages were found in ${NGINX_DEB_DIR}. Add nginx .deb packages there, or install nginx on the server image before upload."
        fi
    fi
    if ! command -v nginx >/dev/null 2>&1; then
        die "nginx command is still unavailable after offline install."
    fi
    if ! command -v systemctl >/dev/null 2>&1; then
        warn "systemd is unavailable; skipping nginx setup."
        return 0
    fi

    local server_name nginx_conf
    server_name="${BEAUTYNET_SERVER_NAME:-${DEFAULT_DOMAIN}}"
    nginx_conf="/etc/nginx/sites-available/${APP_NAME}"
    info "Configuring nginx reverse proxy for ${server_name}..."

    if [ "$(id -u)" -ne 0 ]; then
        sudo tee "$nginx_conf" >/dev/null <<EOF
server {
    listen 80;
    server_name ${server_name} _;

    client_max_body_size 60M;
    keepalive_timeout 30;
    sendfile on;

    gzip on;
    gzip_comp_level 5;
    gzip_min_length 1024;
    gzip_vary on;
    gzip_types text/plain text/css application/json application/javascript application/xml image/svg+xml;

    location /static/ {
        alias ${PROJECT_DIR}/staticfiles/;
        access_log off;
        expires 30d;
        add_header Cache-Control "public, max-age=2592000";
        try_files \$uri =404;
    }

    location = /sw.js {
        proxy_pass http://${BIND_ADDRESS};
        proxy_http_version 1.1;
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto \$scheme;
        add_header Cache-Control "no-store, no-cache, must-revalidate, proxy-revalidate" always;
        expires off;
    }

    location /media/ {
        alias ${PROJECT_DIR}/media/;
        expires off;
        add_header Cache-Control "no-cache, must-revalidate";
        try_files \$uri =404;
    }

    location / {
        proxy_pass http://${BIND_ADDRESS};
        proxy_http_version 1.1;
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto \$scheme;
        proxy_redirect off;
    }
}
EOF
        sudo ln -sfn "$nginx_conf" "/etc/nginx/sites-enabled/${APP_NAME}"
        sudo rm -f /etc/nginx/sites-enabled/default
        sudo nginx -t
        sudo systemctl enable nginx
        sudo systemctl reload nginx || sudo systemctl restart nginx
        NGINX_ACTIVE=1
        return 0
    fi

    cat > "$nginx_conf" <<EOF
server {
    listen 80;
    server_name ${server_name} _;

    client_max_body_size 60M;
    keepalive_timeout 30;
    sendfile on;

    gzip on;
    gzip_comp_level 5;
    gzip_min_length 1024;
    gzip_vary on;
    gzip_types text/plain text/css application/json application/javascript application/xml image/svg+xml;

    location /static/ {
        alias ${PROJECT_DIR}/staticfiles/;
        access_log off;
        expires 30d;
        add_header Cache-Control "public, max-age=2592000";
        try_files \$uri =404;
    }

    location = /sw.js {
        proxy_pass http://${BIND_ADDRESS};
        proxy_http_version 1.1;
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto \$scheme;
        add_header Cache-Control "no-store, no-cache, must-revalidate, proxy-revalidate" always;
        expires off;
    }

    location /media/ {
        alias ${PROJECT_DIR}/media/;
        expires off;
        add_header Cache-Control "no-cache, must-revalidate";
        try_files \$uri =404;
    }

    location / {
        proxy_pass http://${BIND_ADDRESS};
        proxy_http_version 1.1;
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto \$scheme;
        proxy_redirect off;
    }
}
EOF
    ln -sfn "$nginx_conf" "/etc/nginx/sites-enabled/${APP_NAME}"
    rm -f /etc/nginx/sites-enabled/default
    nginx -t
    systemctl enable nginx
    systemctl reload nginx || systemctl restart nginx
    NGINX_ACTIVE=1
}

start_without_systemd() {
    # shellcheck disable=SC1091
    . "${VENV_DIR}/bin/activate"
    load_env

    local pid_file="${PROJECT_DIR}/${APP_NAME}.pid"
    if [ "${BIND_ADDRESS##*:}" = "80" ] && [ "$(id -u)" -ne 0 ]; then
        die "Port 80 needs systemd capability or root. Run ./install on Ubuntu with sudo available, or run: sudo BEAUTYNET_BIND=0.0.0.0:80 ./install"
    fi
    if [ -f "$pid_file" ] && kill -0 "$(cat "$pid_file")" >/dev/null 2>&1; then
        warn "${APP_NAME} is already running with PID $(cat "$pid_file")."
        return
    fi

    info "Starting gunicorn without systemd..."
    nohup gunicorn beautynet.wsgi:application \
        --bind "$BIND_ADDRESS" \
        --workers "$GUNICORN_WORKERS" \
        --timeout "$GUNICORN_TIMEOUT" \
        --access-logfile "${LOG_DIR}/access.log" \
        --error-logfile "${LOG_DIR}/error.log" \
        > "${LOG_DIR}/gunicorn.log" 2>&1 &
    echo $! > "$pid_file"
}

main() {
    cd "$PROJECT_DIR"
    need_cmd ls

    PYTHON="$(pick_python)"
    export PYTHON
    select_wheelhouse
    assert_wheelhouse

    write_default_env
    install_python_packages
    run_django_setup
    ensure_runtime_permissions

    if install_systemd_service; then
        install_nginx_proxy
        info "Deployment complete. systemd service: ${APP_NAME}"
        info "Status: systemctl status ${APP_NAME}"
    else
        start_without_systemd
        info "Deployment complete. Gunicorn PID: $(cat "${PROJECT_DIR}/${APP_NAME}.pid")"
        info "Logs: ${LOG_DIR}/gunicorn.log"
    fi

    if [ "$NGINX_ACTIVE" = "1" ]; then
        info "App URL: ${DEFAULT_ORIGIN}/"
        info "Django upstream: http://${BIND_ADDRESS}/"
    elif [ "${BIND_ADDRESS##*:}" = "80" ]; then
        info "App URL: ${DEFAULT_ORIGIN}/"
    else
        info "App URL: ${DEFAULT_ORIGIN}:${BIND_ADDRESS##*:}/"
    fi
    warn "No SSL is configured. This deployment is HTTP-only on port ${BIND_ADDRESS##*:}."
}

main "$@"
